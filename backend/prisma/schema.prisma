generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  Client
  Manager
  Mechanic
  Accountant
  Admin
}

enum PartFieldType {
  text
  number
  date
  boolean
}

enum BoxStatus {
  free
  busy
  maintenance
}

enum OrderStatus {
  planned
  in_progress
  ready_for_delivery
  completed
  canceled
}

enum PaymentMethod {
  cash
  card
  transfer
}

enum PaymentStatus {
  pending
  completed
}

// ====================== Користувачі ======================
model User {
  id            Int      @id @default(autoincrement())
  username      String   @unique @db.VarChar(50)
  email         String   @unique @db.VarChar(255)
  passwordHash  String   @db.VarChar(255)
  phone         String?  @unique @db.VarChar(32)
  role          UserRole
  createdAt     DateTime @default(now())

  client        Client?
  worker        Worker?
}

// ====================== Клієнти ======================
model Client {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  vehicles  Vehicle[]
  orders    Order[]
}

// ====================== Працівники ======================
model Worker {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  position    String
  hourlyRate  Decimal

  orderServices OrderService[]
}

// ====================== Деталі ======================
model PartCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now())

  parts       Part[]
  fields      PartCategoryField[]
}

model Part {
  id              Int      @id @default(autoincrement())
  categoryId      Int
  category        PartCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  article         String   @unique @db.VarChar(100)
  name            String   @db.VarChar(255)
  basePrice       Decimal
  stockQuantity   Int      @default(0)
  supplier        String?  @db.VarChar(255)
  createdAt       DateTime @default(now())

  customFields    PartCustomField[]
  orderParts      OrderPart[]
}

model PartCategoryField {
  id           Int      @id @default(autoincrement())
  categoryId   Int
  category     PartCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  fieldName    String   @db.VarChar(255)
  fieldType    PartFieldType
  isRequired   Boolean  @default(false)
  createdAt    DateTime @default(now())

  customFields PartCustomField[]
}

model PartCustomField {
  id          Int      @id @default(autoincrement())
  partId      Int
  part        Part     @relation(fields: [partId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  fieldId     Int
  field       PartCategoryField @relation(fields: [fieldId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  fieldValue  String
  createdAt   DateTime @default(now())
}

// ====================== Послуги ======================
model Service {
  id               Int      @id @default(autoincrement())
  name             String   @db.VarChar(255)
  description      String?  @db.Text
  standardPrice    Decimal
  durationMinutes  Int
  createdAt        DateTime @default(now())

  orderServices    OrderService[]
}

// ====================== Бокси ======================
model Box {
  id         Int      @id @default(autoincrement())
  boxNumber  String   @unique @db.VarChar(32)
  status     BoxStatus
  capacity   Int      @default(1)

  orders     Order[]
}

// ====================== Замовлення ======================
model Order {
  id                     Int      @id @default(autoincrement())
  clientId               Int
  vehicleId              Int
  boxId                  Int
  orderDate              DateTime
  startTime              DateTime
  totalDurationMinutes   Int?
  status                 OrderStatus @default(planned)
  totalAmount            Decimal  @default(0)
  notes                  String?  @db.Text
  createdAt              DateTime @default(now())

  client        Client         @relation(fields: [clientId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  vehicle       Vehicle        @relation(fields: [vehicleId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  box           Box            @relation(fields: [boxId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  orderServices OrderService[]
  orderParts    OrderPart[]
  payments      Payment[]
}

model OrderService {
  orderId                Int
  serviceId              Int
  workerId               Int
  actualDurationMinutes  Int?
  actualCost             Decimal?

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([orderId, serviceId])
}

model OrderPart {
  orderId    Int
  partId     Int
  quantity   Int
  unitPrice  Decimal

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  part  Part  @relation(fields: [partId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@id([orderId, partId])
}

model Payment {
  id             Int      @id @default(autoincrement())
  orderId        Int
  amount         Decimal
  paymentDate    DateTime @default(now())
  paymentMethod  PaymentMethod
  status         PaymentStatus @default(pending)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model Vehicle {
  id            Int      @id @default(autoincrement())
  clientId      Int
  make          String   @db.VarChar(100)
  model         String   @db.VarChar(100)
  year          Int
  vin           String   @unique @db.VarChar(32)
  licensePlate  String   @unique @db.VarChar(32)
  kilometrage   Int?
  createdAt     DateTime @default(now())

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  orders  Order[]
}
